{
  "name": "@openfinance/shared",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "db:check": "drizzle-kit push:pg --dry-run --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:generate-custom": "drizzle-kit generate --custom --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "type-check": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./redis": "./src/redis/index.ts",
    "./types": "./src/types/index.ts",
    "./trpc": "./src/trpc/index.ts",
    "./validations": "./src/validations/index.ts"
  },
  "files": [
    "src"
  ],
  "dependencies": {
    "@trpc/server": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.11.0",
    "postgres": "^3.4.9",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.5",
    "dotenv": "^17.4.2",
    "esbuild": "^0.19.11",
    "esbuild-register": "^3.5.0",
    "typescript": "^5.6.2"
  }
}