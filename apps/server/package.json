{
  "name": "@openfinance/server",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch index.ts",
    "build": "bun build index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "queue:start": "bun run scripts/start-queue.ts",
    "queue:stop": "bun run scripts/stop-queue.ts",
    "type-check": "tsc --noEmit"
  },
  "exports": {
    "./trpc": "./src/trpc/router.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.21.0",
    "@bull-board/hono": "^6.21.0",
    "@hono/node-server": "^1.19.13",
    "@hono/trpc-server": "^0.4.2",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/google": "^0.1.12",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.4.7",
    "@openfinance/shared": "workspace:*",
    "@trpc/server": "^11.17.0",
    "@types/papaparse": "^5.5.2",
    "bullmq": "^5.73.1",
    "fast-xml-parser": "^5.8.0",
    "hono": "^4.0.11",
    "langchain": "^1.4.2",
    "papaparse": "^5.5.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.2"
  }
}